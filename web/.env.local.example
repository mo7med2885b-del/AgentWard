# Copy to .env.local (gitignored). Fill with real values.

# --- LLM providers ---
# Featherless: used by Management, Investigation, Documentation, Observer.
FEATHERLESS_API_KEY=your_featherless_key
# OpenRouter: used by Triage only (Claude Sonnet 4.6), to keep it off the
# Featherless concurrency budget so Triage + Management run in parallel.
OPENROUTER_API_KEY=your_openrouter_key

# --- Evidence tools ---
NCBI_API_KEY=your_ncbi_key
TAVILY_API_KEY=your_tavily_key

# --- Band coordination layer ---
# Fallback room used if "New Band room each run" is off. A fresh room is
# normally created per case at runtime.
BAND_CHAT_ROOM_ID=your_band_room_uuid
# Your Band user UUID — added as owner to freshly-created rooms so you can watch.
BAND_USER_ID=your_band_user_uuid

# Each agent's Band agent API key + UUID + handle (used to post as that agent).
TRIAGE_API_KEY=band_a_...
TRIAGE_AGENT_ID=your_triage_agent_uuid
TRIAGE_HANDLE=@yourname/triageagent

MGMT_API_KEY=band_a_...
MGMT_AGENT_ID=your_management_agent_uuid
MGMT_HANDLE=@yourname/managementagent

INVEST_API_KEY=band_a_...
INVEST_AGENT_ID=your_investigation_agent_uuid
INVEST_HANDLE=@yourname/investigationagent

DOC_API_KEY=band_a_...
DOC_AGENT_ID=your_documentation_agent_uuid
DOC_HANDLE=@yourname/documentationagent

OBSERVER_API_KEY=band_a_...
OBSERVER_AGENT_ID=your_observer_agent_uuid
OBSERVER_HANDLE=@yourname/observeragent
