# Copy to .env.local (gitignored). Fill with real values.

# --- LLM providers (cascade: AIML first, Featherless fallback) ---
AIMLAPI_KEY=your_aiml_key
AIML_MODEL=anthropic/claude-sonnet-4-6-20260218
FEATHERLESS_API_KEY=your_featherless_key
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

# --- Evidence tools ---
NCBI_API_KEY=your_ncbi_key
TAVILY_API_KEY=your_tavily_key

# --- Band coordination layer ---
BAND_CHAT_ROOM_ID=53c29766-271a-4b84-bfd9-3344d08b4c9d

# Each agent's Band agent API key + UUID + handle (used to post as that agent).
TRIAGE_API_KEY=band_a_...
TRIAGE_AGENT_ID=247001be-948a-42fe-9fbd-0fa54e96c10a
TRIAGE_HANDLE=@mokhalaf2885/triageagent

MGMT_API_KEY=band_a_...
MGMT_AGENT_ID=85410e84-29a5-4b58-8094-5474e89293bd
MGMT_HANDLE=@mokhalaf2885/managementagent

INVEST_API_KEY=band_a_...
INVEST_AGENT_ID=1e6d749c-bc80-4850-9b14-7c64a9d6cf69
INVEST_HANDLE=@mokhalaf2885/investigationagent

DOC_API_KEY=band_a_...
DOC_AGENT_ID=9258e4fe-ef6a-4e10-a064-f8b3dd4daa41
DOC_HANDLE=@mokhalaf2885/documentationagent

OBSERVER_API_KEY=band_a_...
